# Backend API URL — set this to connect to the real backend on the GX10
# Without this, the frontend uses built-in Next.js mock API routes
#
# Examples:
#   NEXT_PUBLIC_API_URL=http://localhost:8000        # Local backend
#   NEXT_PUBLIC_API_URL=http://192.168.1.100:8000    # GX10 on LAN
#
# The backend provides WebSocket URLs in its /api/design response,
# so no separate WS URL config is needed.
NEXT_PUBLIC_API_URL=http://localhost:8000
